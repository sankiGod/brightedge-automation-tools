# Zendesk
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=you@yourcompany.com
ZENDESK_API_TOKEN=your_zendesk_api_token

# BrightEdge
BRIGHTEDGE_PASSWORD=your_brightedge_password
BE_LOGIN_URL=https://www.brightedge.com/secure/login

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Microsoft Teams (incoming webhook)
# Setup: Teams channel → ... → Connectors → Incoming Webhook → Configure → copy URL
TEAMS_WEBHOOK_URL=https://brightedge.webhook.office.com/webhookb2/...

# Orchestrator mode
# Set to "true" to use Cowork as the orchestrator instead of the Anthropic API.
# Cowork reads cowork_ticket.json and writes cowork_decision.json to continue the pipeline.
COWORK_ORCHESTRATOR=false

# Fuzzy matching thresholds (optional — defaults: 0.6 and 0.5)
FUZZY_SHEET_THRESHOLD=0.6
FUZZY_FILE_THRESHOLD=0.5

# Celery / Redis (production — not yet implemented)
# REDIS_URL=redis://localhost:6379/0
